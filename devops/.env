# ==============================================================================
# INFRASTRUCTURE CONFIGURATION (SonarQube + Floci)
# ==============================================================================

# --- SonarQube & Postgres DB ---
SONAR_VERSION=community
SONAR_JDBC_USERNAME=sonar
SONAR_JDBC_PASSWORD=sonar
SONAR_JDBC_URL=jdbc:postgresql://sonar-db:5432/sonar

POSTGRES_USER=sonar
POSTGRES_PASSWORD=sonar
POSTGRES_DB=sonar

# --- Floci (AWS Emulator) ---
FLOCI_PORT=4566
FLOCI_DEFAULT_REGION=us-east-1
FLOCI_DEFAULT_ACCOUNT_ID=000000000000
FLOCI_HOSTNAME=floci
FLOCI_BASE_URL=http://localhost:4566

# Persistence
FLOCI_STORAGE_MODE=persistent
FLOCI_STORAGE_PERSISTENT_PATH=/app/data

# Networking Integration
# Using 'sonarnet' to allow services to talk to each other
FLOCI_SERVICES_DOCKER_NETWORK=sonarnet
FLOCI_SERVICES_LAMBDA_DOCKER_NETWORK=sonarnet

# Service Parity (Match Sonar DB version or preference)
FLOCI_SERVICES_RDS_DEFAULT_POSTGRES_IMAGE=postgres:15

# --- Local Client Config (For reference/scripts) ---
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566
